{
  "name": "photo-file-explorer",
  "version": "1.0.0",
  "description": "A cross-platform photo management desktop application",
  "main": "dist-electron/main/index.js",
  "author": "Photo File Explorer",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:win": "electron-vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:mac": "electron-vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "exifr": "^7.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.photofileexplorer.app",
    "productName": "Photo File Explorer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**"
    ],
    "win": {
      "sign": null,
      "signingHashAlgorithms": null,
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "sign": null,
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.photography"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
